        <item name="android:colorBackground">@color/purple_dark_background</item>
        <item name="colorOnBackground">@color/purple_dark_onBackground</item>
        <item name="colorSurface">@color/purple_dark_surface</item>
        <item name="colorOnSurface">@color/purple_dark_onSurface</item>
        <item name="colorSurfaceVariant">@color/purple_dark_surfaceVariant</item>
