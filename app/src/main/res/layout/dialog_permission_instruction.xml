<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:padding="16dp">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical">

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="To record notifications, please follow these steps:\n\n1. Find 'Notification Vault' in the list and turn on 'Allow notification access'."
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:layout_marginBottom="8dp"/>

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:src="@drawable/instruction_step1"
            android:layout_marginBottom="16dp"
            android:scaleType="fitCenter"
            android:clipToOutline="true"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="2. Tap 'Allow' in the confirmation popup."
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:layout_marginBottom="8dp"/>

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:src="@drawable/instruction_step2"
            android:layout_marginBottom="16dp"
            android:scaleType="fitCenter"
            android:clipToOutline="true"/>

        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="3. Finally, ensure all the checkboxes are ticked (Real-time, Conversations, Notifications, Silent)."
            android:textAppearance="?attr/textAppearanceBodyMedium"
            android:layout_marginBottom="8dp"/>

        <ImageView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:adjustViewBounds="true"
            android:src="@drawable/instruction_step3"
            android:layout_marginBottom="8dp"
            android:scaleType="fitCenter"
            android:clipToOutline="true"/>

    </LinearLayout>
</ScrollView>
