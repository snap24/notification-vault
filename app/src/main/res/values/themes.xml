<?xml version="1.0" encoding="utf-8"?>
<resources>
    <!-- Base application theme. -->
    <style name="Theme.NotiVault" parent="Theme.Material3.DayNight.NoActionBar">
        <item name="android:windowSoftInputMode">adjustResize</item>
        <item name="android:statusBarColor">@android:color/transparent</item>
        <item name="android:navigationBarColor">@android:color/transparent</item>
        <item name="android:windowLightStatusBar">true</item>
    </style>

    <!-- Purple Theme (Default) -->
    <style name="Theme.NotiVault.Purple" parent="Theme.NotiVault">
        <item name="colorPrimary">@color/purple_light_primary</item>
        <item name="colorOnPrimary">@color/purple_light_onPrimary</item>
        <item name="colorPrimaryContainer">@color/purple_light_primaryContainer</item>
        <item name="colorOnPrimaryContainer">@color/purple_light_onPrimaryContainer</item>
        <item name="colorSecondary">@color/purple_light_secondary</item>
        <item name="colorOnSecondary">@color/purple_light_onSecondary</item>
        <item name="colorSecondaryContainer">@color/purple_light_secondaryContainer</item>
        <item name="colorOnSecondaryContainer">@color/purple_light_onSecondaryContainer</item>
        <item name="android:colorBackground">@color/purple_light_background</item>
        <item name="colorOnBackground">@color/purple_light_onBackground</item>
        <item name="colorSurface">@color/purple_light_surface</item>
        <item name="colorOnSurface">@color/purple_light_onSurface</item>
        <item name="colorSurfaceVariant">@color/purple_light_surfaceVariant</item>
        <item name="colorOnSurfaceVariant">@color/purple_light_onSurfaceVariant</item>
        <item name="colorOutline">@color/purple_light_outline</item>
        <item name="colorOutlineVariant">@color/purple_light_outlineVariant</item>
        <item name="colorSurfaceContainerHigh">@color/purple_light_surfaceContainerHigh</item>
    </style>

